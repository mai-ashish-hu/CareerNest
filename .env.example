# ── App ──
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:5173

# ── Appwrite ──
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PUBLIC_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id
APPWRITE_API_KEY=your_api_key

# ── Database ──
APPWRITE_DATABASE_ID=careernest_db

# ── Collection IDs ──
COLLECTION_TENANTS=colleges
COLLECTION_USERS=users
COLLECTION_STUDENTS=students
COLLECTION_STUDENT_PROFILES=student_profiles
COLLECTION_STUDENT_ACHIEVEMENTS=student_profile_achievements
COLLECTION_STUDENT_EDUCATION=student_profile_education
COLLECTION_STUDENT_EXPERIENCE=student_profile_experience
COLLECTION_STUDENT_PROJECTS=student_profile_projects
COLLECTION_STUDENT_SKILLS=student_profile_skills
COLLECTION_COMPANIES=companies
COLLECTION_DRIVES=drives
COLLECTION_APPLICATIONS=applications
COLLECTION_COURSES=courses
COLLECTION_DEPARTMENTS=departements
COLLECTION_ANNOUNCEMENTS=announcements
COLLECTION_PLACEMENT_RECORDS=placement_records
COLLECTION_AUDIT_LOGS=audit_logs
COLLECTION_CAMPUS_CHAT_CHANNELS=campus_chat_channels
COLLECTION_CAMPUS_CHAT_MESSAGES=campus_chat_messages

# ── Storage ──
APPWRITE_BUCKET_RESUMES=resumes
APPWRITE_BUCKET_PROFILE_PHOTOS=profilePhoto
APPWRITE_BUCKET_CERTIFICATES=certificates

# ── Email (SMTP) ──
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@careernest.com
SMTP_PASS=your_smtp_password
SMTP_FROM=CareerNest <noreply@careernest.com>

# ── Rate Limiting ──
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── JWT Secret (for custom token signing if needed) ──
JWT_SECRET=your_jwt_secret_here
